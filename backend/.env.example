MONGO_URI=
PORT=
JWT_SECRET=
FRONTEND_URL=
EMAIL_USER=
EMAIL_PASS=
SKIP_EMAIL_VERIFICATION=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Phase 4 — OAuth (GitHub/Google/LinkedIn login + account linking)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Base URL OAuth providers redirect back to, e.g. http://localhost:3008
OAUTH_CALLBACK_BASE_URL=
# AES-256-GCM key (64 hex chars) for encrypting linked-account tokens at rest:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Phase 5 — Video Calling (LiveKit)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Phase 6 — Premium Subscriptions & Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Razorpay plan_id for the 'premium' Plan, used by seedPlans.js
RAZORPAY_PREMIUM_PLAN_ID=

# Phase 6 — AI Developer Assistant (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_DAILY_LIMIT=20

# Phase 7 — Observability
# pino log level (trace|debug|info|warn|error|fatal); defaults to 'info'
LOG_LEVEL=info
# Sentry error tracking — leave unset to disable (no-op locally/in tests)
SENTRY_DSN=

# Phase 10 — Redis (caching, distributed rate-limit, Socket.IO adapter,
# presence, BullMQ event queues). LEAVE UNSET to run the app as a single-
# instance monolith with in-memory fallbacks (and inline job execution).
# Local: `docker compose up -d` then set:
#   REDIS_URL=redis://localhost:6379
REDIS_URL=
# Per-worker BullMQ job concurrency (worker process only); defaults to 5.
WORKER_CONCURRENCY=5
